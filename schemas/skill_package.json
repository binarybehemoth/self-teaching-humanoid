{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/clphang/self-teaching-humanoid/schemas/skill_package.json",
  "title": "Skill Package / Dependency Record",
  "description": "A composed skill and its dependency tree, with pinned versions and signed provenance for supply-chain security.",
  "type": "object",
  "required": ["schema_version", "name", "version", "dependencies"],
  "properties": {
    "schema_version": {"type": "string"},
    "name": {"type": "string"},
    "version": {"type": "string"},
    "provenance": {"type": "object", "properties": {
      "author": {"type": "string"}, "signature": {"type": "string"}}},
    "dependencies": {
      "type": "array",
      "items": {"type": "object", "required": ["name", "version"], "properties": {
        "name": {"type": "string"},
        "version": {"type": "string", "description": "Pinned, locked version"},
        "signature": {"type": "string", "description": "Verified provenance"}
      }}
    }
  }
}
