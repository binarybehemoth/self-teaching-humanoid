{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/clphang/self-teaching-humanoid/schemas/skill_listing.json",
  "title": "Marketplace Skill Listing",
  "description": "A skill offered for exchange on the marketplace (Parts XV–XVII).",
  "type": "object",
  "required": ["schema_version", "name", "effect", "precondition", "requires", "verified"],
  "properties": {
    "schema_version": {"type": "string"},
    "name": {"type": "string"},
    "version": {"type": "string"},
    "author": {"type": "string"},
    "effect": {"type": "string", "description": "What the skill achieves"},
    "precondition": {"type": "string", "description": "What must hold to run it"},
    "requires": {
      "type": "object",
      "description": "The body this skill needs (Vol 5 capability negotiation)",
      "properties": {
        "arms": {"type": "integer", "minimum": 0},
        "reach_m": {"type": "number", "minimum": 0},
        "sensors": {"type": "array", "items": {"type": "string"}}
      }
    },
    "dependencies": {"type": "array", "items": {"type": "string"},
      "description": "Skills this one builds on (Vol 5, Ch 40)"},
    "competence": {"type": "object", "properties": {
      "estimate": {"type": "number"}, "attempts": {"type": "integer"}}},
    "verified": {"type": "boolean", "description": "Passed the trust layer (Ch 37)"}
  }
}
